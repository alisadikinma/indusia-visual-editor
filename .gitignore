# --- Sensitive: customer data + legacy code ---
data/
old-code/
.sync/
# Carve-out: in-tree, committed taxonomy/config YAML that lives under
# src/indusia_visual_editor/data/ — these are app-shipped data files,
# not customer data. The blanket `data/` ignore is for top-level
# fixture / customer dumps only.
!src/indusia_visual_editor/data/
!src/indusia_visual_editor/data/**

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env
.env.*
!.env.example
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# --- Node / Frontend ---
node_modules/
.pnp/
.pnp.js
web/dist/
web/build/
web/.vite/
web/.next/
web/.nuxt/
web/coverage/
web/.turbo/
web/*.tsbuildinfo

# --- LSF vendored bundle (built artifact, not source) ---
web/public/lsf/main.js
web/public/lsf/main.css
web/public/lsf/*.map

# --- Secrets ---
license/
*.key
*.pem
*.crt
.npmrc
.yarnrc.yml

# --- Runtime / generated ---
storage/
logs/
.cache/
.spike-logs/
*.log
model_state.json

# --- IDE / OS ---
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# --- Claude Code + Playwright MCP local caches ---
.claude/
.playwright-mcp/

# --- Poetry ---
# poetry.lock IS committed (standard practice, deterministic installs).

# --- Docker ---
docker-compose.override.yml

# --- Misc ---
*.bak
*.tmp
*.orig

# --- graphify (local graph-generation tool — output not tracked) ---
graphify-out/
.graphifyignore
