# Frontend environment variables — Vite reads these at build/dev time.
# Copy to .env.local (which is gitignored) and edit. Only variables prefixed
# with VITE_ are exposed to the client bundle.

# Set to "false" to disable the MSW dev-mode mock service worker and proxy
# real /api calls through to the backend (default: MSW intercepts everything).
# Useful when smoke-testing against a live FastAPI instance on :8002.
VITE_USE_MSW=true
