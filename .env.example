# Indusia Visual Editor — environment variables (all prefixed IVE_)
# Copy to .env and edit. .env is gitignored.

# --- Application ---
IVE_APP_HOST=0.0.0.0
IVE_APP_PORT=8002
IVE_LOG_LEVEL=INFO

# --- Database (docker-compose.dev.yml postgres service) ---
# host=localhost:5433 when running api locally against dockerized postgres
#   (host port 5433 — 5432 reserved to avoid clashes with native Postgres)
# host=postgres:5432 when running api inside docker-compose network
IVE_DATABASE_URL=postgresql+asyncpg://ive:ive@localhost:5433/ive

# --- Storage (Phase 1.3+) ---
IVE_STORAGE_ROOT=./storage

# --- Ollama (Phase 3.1+) ---
IVE_OLLAMA_URL=http://localhost:11434
IVE_OLLAMA_MODEL_PLANNER=gemma4:31b
IVE_OLLAMA_MODEL_PRELABEL=gemma4:31b
IVE_OLLAMA_TIMEOUT=120

# --- Sibling auto-inspect-service (Phase 7+) ---
IVE_INSPECT_SERVICE_URL=http://localhost:8001
